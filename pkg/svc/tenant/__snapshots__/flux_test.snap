[TestGenerateFluxSyncManifests/oci_source_with_registry_and_tenant-repo - 1]
apiVersion: source.toolkit.fluxcd.io/v1
kind: OCIRepository
metadata:
  labels:
    app.kubernetes.io/managed-by: ksail
  name: team-alpha
  namespace: team-alpha-ns
spec:
  interval: 1m
  ref:
    tag: latest
  url: oci://ghcr.io/acme-org/team-alpha-manifests
/-/-/-/
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  labels:
    app.kubernetes.io/managed-by: ksail
  name: team-alpha
  namespace: team-alpha-ns
spec:
  interval: 1m
  path: ./k8s
  prune: true
  serviceAccountName: team-alpha
  sourceRef:
    kind: OCIRepository
    name: team-alpha
  targetNamespace: team-alpha-ns

---
