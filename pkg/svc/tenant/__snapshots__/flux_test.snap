
[TestGenerateFluxSyncManifests/git_source_with_github_provider - 1]
apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  labels:
    app.kubernetes.io/managed-by: ksail
  name: team-beta
  namespace: team-beta-ns
spec:
  interval: 1m
  ref:
    branch: main
  url: https://github.com/acme-org/team-beta-config
/-/-/-/
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  labels:
    app.kubernetes.io/managed-by: ksail
  name: team-beta
  namespace: team-beta-ns
spec:
  interval: 1m
  path: ./k8s
  prune: true
  serviceAccountName: team-beta
  sourceRef:
    kind: GitRepository
    name: team-beta
  targetNamespace: team-beta-ns

---

