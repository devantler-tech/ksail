[TestToolSurfaceSnapshot/workload_write - 1]
{
  "name": "workload_write",
  "title": "Workload Write",
  "description": "Manage workload operations",
  "commandPath": "ksail workload",
  "requiresPermission": true,
  "isConsolidated": true,
  "subcommandParam": "workload_command",
  "annotations": {
    "readOnlyHint": false,
    "destructiveHint": true,
    "idempotentHint": false,
    "openWorldHint": true
  },
  "parameters": {
    "properties": {
      "add-key": {
        "description": "public key to add as a master key recipient (applies to: cipher_rotate)",
        "type": "string"
      },
      "aggregation-rule": {
        "description": "An aggregation label selector for combining ClusterRoles. (applies to: create_clusterrole)",
        "type": "string"
      },
      "all": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details (applies to: apply, apply_view-last-applied, delete, scale)",
        "type": "boolean"
      },
      "all-namespaces": {
        "description": "If present, list the requested object(s) across all namespaces. Namespace in current context is ignored even if specified with --namespace. (applies to: delete)",
        "type": "boolean"
      },
      "allow-missing-template-keys": {
        "default": true,
        "description": "If true, ignore any errors in templates when a field or map key is missing in the template. Only applies to golang and jsonpath output formats.",
        "type": "boolean"
      },
      "annotation": {
        "description": "Annotation to insert in the ingress object, in the format annotation=value (applies to: create_ingress)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "append-hash": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details (applies to: create_configmap, create_secret_docker-registry, create_secret_generic, create_secret_tls)",
        "type": "boolean"
      },
      "args": {
        "description": "Positional arguments for the command (applies to: apply, apply_edit-last-applied, apply_set-last-applied, apply_view-last-applied, cipher_decrypt, cipher_edit, cipher_encrypt, cipher_import, cipher_rotate, create, create_clusterrole, create_clusterrolebinding, create_configmap, create_cronjob, create_deployment, create_helmrelease, create_ingress, create_job, create_kustomization, create_namespace, create_poddisruptionbudget, create_priorityclass, create_quota, create_role, create_rolebinding, create_secret, create_secret_docker-registry, create_secret_generic, create_secret_tls, create_service, create_service_clusterip, create_service_externalname, create_service_loadbalancer, create_service_nodeport, create_serviceaccount, create_source_git, create_source_helm, create_source_oci, create_token, debug, delete, exec, expose, import, install, mirror, push, reconcile, rollout, rollout_history, rollout_pause, rollout_restart, rollout_resume, rollout_status, rollout_undo, scale)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "arguments-only": {
        "description": "If specified, everything after -- will be passed to the new container as Args instead of Command. (applies to: debug)",
        "type": "boolean"
      },
      "atomic": {
        "description": "if set, the installation deletes on failure (applies to: install)",
        "type": "boolean"
      },
      "attach": {
        "description": "If true, wait for the container to start running, and then attach as if 'kubectl attach ...' were called.  Default false, unless '-i/--stdin' is set, in which case the default is true. (applies to: debug)",
        "type": "boolean"
      },
      "audience": {
        "description": "Audience of the requested token. If unset, defaults to requesting a token for use with the Kubernetes API server. May be repeated to request a token valid for multiple audiences. (applies to: create_token)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "bound-object-kind": {
        "description": "Kind of an object to bind the token to. Supported kinds are Node, Pod, Secret. If set, --bound-object-name must be provided. (applies to: create_token)",
        "type": "string"
      },
      "bound-object-name": {
        "description": "Name of an object to bind the token to. The token will expire when the object is deleted. Requires --bound-object-kind. (applies to: create_token)",
        "type": "string"
      },
      "bound-object-uid": {
        "description": "UID of an object to bind the token to. Requires --bound-object-kind and --bound-object-name. If unset, the UID of the existing object is used. (applies to: create_token)",
        "type": "string"
      },
      "branch": {
        "description": "git branch (applies to: create_source_git)",
        "type": "string"
      },
      "cascade": {
        "default": "background",
        "description": "Must be \"background\", \"orphan\", or \"foreground\". Selects the deletion cascading strategy for the dependents (e.g. Pods created by a ReplicationController). Defaults to background. (applies to: apply, delete)",
        "type": "string"
      },
      "cert": {
        "description": "Path to PEM encoded public key certificate. (applies to: create_secret_tls)",
        "type": "string"
      },
      "chart": {
        "description": "Helm chart name or path (applies to: create_helmrelease)",
        "type": "string"
      },
      "chart-version": {
        "description": "Helm chart version (applies to: create_helmrelease)",
        "type": "string"
      },
      "class": {
        "description": "Ingress Class to be used (applies to: create_ingress)",
        "type": "string"
      },
