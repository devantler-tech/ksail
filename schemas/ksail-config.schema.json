{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "Cluster"
      ]
    },
    "apiVersion": {
      "type": "string",
      "enum": [
        "ksail.io/v1alpha1"
      ]
    },
    "metadata": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Cluster name (DNS-1123 compliant)"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "spec": {
      "properties": {
        "editor": {
          "type": "string",
          "description": "Editor command for interactive workflows (e.g. code --wait)"
        },
        "cluster": {
          "properties": {
            "distributionConfig": {
              "type": "string"
            },
            "connection": {
              "properties": {
                "kubeconfig": {
                  "type": "string"
                },
                "context": {
                  "type": "string"
                },
                "timeout": {
                  "type": "string",
                  "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "distribution": {
              "type": "string",
              "enum": [
                "Vanilla",
                "K3s",
                "Talos",
                "VCluster",
                "KWOK",
                "EKS"
              ]
            },
            "provider": {
              "type": "string",
              "enum": [
                "Docker",
                "Hetzner",
                "Omni",
                "AWS",
                "Kubernetes"
              ]
            },
            "cni": {
              "type": "string",
              "enum": [
                "Default",
                "Cilium",
                "Calico"
              ]
            },
            "csi": {
              "type": "string",
              "enum": [
                "Default",
                "Enabled",
                "Disabled"
              ]
            },
            "cdi": {
              "type": "string",
              "enum": [
                "Default",
                "Enabled",
                "Disabled"
              ]
            },
            "metricsServer": {
              "type": "string",
              "enum": [
                "Default",
                "Enabled",
                "Disabled"
              ]
            },
            "loadBalancer": {
              "type": "string",
              "enum": [
                "Default",
                "Enabled",
                "Disabled"
              ]
            },
            "certManager": {
              "type": "string",
              "enum": [
                "Enabled",
                "Disabled"
              ]
            },
            "policyEngine": {
              "type": "string",
              "enum": [
                "None",
                "Kyverno",
                "Gatekeeper"
              ]
            },
            "localRegistry": {
              "properties": {
                "registry": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "gitOpsEngine": {
              "type": "string",
              "enum": [
                "None",
                "Flux",
                "ArgoCD"
              ]
            },
            "sops": {
              "properties": {
                "ageKeyEnvVar": {
                  "type": "string"
                },
                "enabled": {
                  "type": "boolean"
                },
                "env": {
                  "properties": {
                    "var": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false,
                  "type": "object"
                },
                "extract": {
                  "properties": {
                    "file": {
                      "type": "string"
                    },
                    "publicKeys": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    }
                  },
                  "additionalProperties": false,
                  "type": "object"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "nodeAutoscaling": {
              "type": "string",
              "enum": [
                "Enabled",
                "Disabled"
              ],
              "description": "Deprecated. Use autoscaler.node.enabled instead. Do not set both nodeAutoscaling and autoscaler."
            },
            "autoscaler": {
              "properties": {
                "pod": {
                  "properties": {
                    "horizontal": {
                      "type": "string",
                      "enum": [
                        "Enabled",
                        "Disabled"
                      ]
                    },
                    "vertical": {
                      "type": "string",
                      "enum": [
                        "Enabled",
                        "Disabled"
                      ]
                    }
                  },
                  "additionalProperties": false,
                  "type": "object"
                },
                "node": {
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "pools": {
                      "items": {
                        "properties": {
                          "name": {
                            "type": "string",
                            "maxLength": 63,
                            "minLength": 1,
                            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
                          },
                          "serverType": {
                            "type": "string",
                            "minLength": 1
                          },
                          "location": {
                            "type": "string",
                            "minLength": 1
                          },
                          "min": {
                            "type": "integer",
                            "minimum": 0
                          },
                          "max": {
                            "type": "integer",
                            "minimum": 0
                          }
                        },
                        "additionalProperties": false,
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "maxNodesTotal": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Maximum total nodes allowed across all node pools. Set to 0 to disable the global cap; when the global cap is disabled the effective cap is the sum of all pool max values"
                    },
                    "expander": {
                      "type": "string",
                      "enum": [
                        "Price",
                        "LeastWaste",
                        "LeastNodes",
                        "Random"
                      ]
                    },
                    "scaleDownUnneededTime": {
                      "type": "string",
                      "description": "How long a node should be unneeded before it is eligible for scale down (e.g. 10m)"
                    }
                  },
                  "additionalProperties": false,
                  "type": "object"
                }
              },
              "additionalProperties": false,
              "type": "object",
              "description": "Pod and node autoscaling configuration (supersedes deprecated nodeAutoscaling)"
            },
            "importImages": {
              "type": "string",
              "description": "Path to tar archive with container images to import after cluster creation but before component installation"
            },
            "controlPlanes": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of control-plane nodes to create for the cluster (provider/distribution-agnostic)"
            },
            "workers": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of worker nodes to create for the cluster (provider/distribution-agnostic)"
            },
            "oidc": {
              "properties": {
                "issuerURL": {
                  "type": "string",
                  "description": "OIDC provider issuer URL"
                },
                "clientID": {
                  "type": "string",
                  "description": "OIDC client ID for kubectl"
                },
                "extraScopes": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Additional OIDC scopes beyond openid"
                },
                "usernameClaim": {
                  "type": "string",
                  "description": "JWT claim for username"
                },
                "usernamePrefix": {
                  "type": "string",
                  "description": "Prefix for OIDC usernames"
                },
                "groupsClaim": {
                  "type": "string",
                  "description": "JWT claim for groups"
                },
                "groupsPrefix": {
                  "type": "string",
                  "description": "Prefix for OIDC groups"
                },
                "caFile": {
                  "type": "string",
                  "description": "CA cert path for self-signed OIDC"
                }
              },
              "additionalProperties": false,
              "type": "object",
              "description": "OIDC authentication configuration for the API server and kubeconfig"
            },
            "vanilla": {
              "properties": {
                "mirrorsDir": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "talos": {
              "properties": {
                "version": {
                  "type": "string"
                },
                "controlPlanes": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "DEPRECATED: use spec.cluster.controlPlanes instead"
                },
                "workers": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "DEPRECATED: use spec.cluster.workers instead"
                },
                "config": {
                  "type": "string"
                },
                "iso": {
                  "type": "integer"
                },
                "schematicId": {
                  "type": "string"
                },
                "extensions": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "extraPortMappings": {
                  "items": {
                    "properties": {
                      "containerPort": {
                        "type": "integer"
                      },
                      "hostPort": {
                        "type": "integer"
                      },
                      "protocol": {
                        "type": "string",
                        "enum": [
                          "TCP",
                          "UDP"
                        ],
                        "default": "TCP"
                      }
                    },
                    "additionalProperties": false,
                    "type": "object"
                  },
                  "type": "array"
                },
                "imageVerification": {
                  "type": "string",
                  "enum": [
                    "Enabled",
                    "Disabled"
                  ]
                }
              },
              "additionalProperties": false,
              "type": "object"
            }
          },
          "additionalProperties": false,
          "type": "object"
        },
        "provider": {
          "properties": {
            "hetzner": {
              "properties": {
                "controlPlaneServerType": {
                  "type": "string"
                },
                "workerServerType": {
                  "type": "string"
                },
                "location": {
                  "type": "string"
                },
                "networkName": {
                  "type": "string"
                },
                "networkCidr": {
                  "type": "string"
                },
                "sshKeyName": {
                  "type": "string"
                },
                "tokenEnvVar": {
                  "type": "string"
                },
                "placementGroupStrategy": {
                  "type": "string",
                  "enum": [
                    "None",
                    "Spread"
                  ]
                },
                "placementGroup": {
                  "type": "string"
                },
                "fallbackLocations": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "placementGroupFallbackToNone": {
                  "type": "boolean"
                },
                "ingressFirewall": {
                  "type": "string",
                  "enum": [
                    "Enabled",
                    "Disabled"
                  ]
                },
                "serverLimit": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Maximum total Hetzner servers allowed for this cluster (control-planes + workers + autoscaler pool capacity). Set to 0 to use the default limit of 10"
                },
                "allowedCidrs": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "CIDR blocks allowed to access the Kubernetes API and Talos API on control-plane nodes. When empty defaults to 0.0.0.0/0 and ::/0 (open to all IPv4 and IPv6)."
                },
                "autoscalerNodePoolNames": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "omni": {
              "properties": {
                "endpoint": {
                  "type": "string"
                },
                "endpointEnvVar": {
                  "type": "string"
                },
                "serviceAccountKeyEnvVar": {
                  "type": "string"
                },
                "talosVersion": {
                  "type": "string"
                },
                "kubernetesVersion": {
                  "type": "string"
                },
                "machineClass": {
                  "type": "string"
                },
                "machines": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "aws": {
              "properties": {
                "profileEnvVar": {
                  "type": "string"
                },
                "regionEnvVar": {
                  "type": "string"
                },
                "accessKeyIdEnvVar": {
                  "type": "string"
                },
                "secretAccessKeyEnvVar": {
                  "type": "string"
                },
                "sessionTokenEnvVar": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "type": "object"
            },
            "kubernetes": {
              "properties": {
                "kubeconfig": {
                  "type": "string"
                },
                "kubeconfigEnvVar": {
                  "type": "string"
                },
                "context": {
                  "type": "string"
                },
                "contextEnvVar": {
                  "type": "string"
                },
                "gatewayClassName": {
                  "type": "string"
                },
                "podCidr": {
                  "type": "string"
                },
                "serviceCidr": {
                  "type": "string"
                },
                "persistence": {
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "storageClassName": {
                      "type": "string"
                    },
                    "size": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false,
                  "type": "object"
                }
              },
              "additionalProperties": false,
              "type": "object"
            }
          },
          "additionalProperties": false,
          "type": "object"
        },
        "workload": {
          "properties": {
            "sourceDirectory": {
              "type": "string",
              "description": "Path to the directory containing Kubernetes manifests. Used as the default path by validate, watch, and push when no explicit path argument is given."
            },
            "validateOnPush": {
              "type": "boolean",
              "description": "Validate manifests against schemas before pushing (validation disabled by default)"
            },
            "tag": {
              "type": "string",
              "description": "OCI artifact tag used for workload push and GitOps reconciliation (Flux OCIRepository and ArgoCD Application). Push priority: CLI oci:// ref \u003e this field \u003e registry-embedded tag \u003e dev. Reconciliation priority: this field \u003e registry-embedded tag \u003e dev"
            },
            "kustomizationFile": {
              "type": "string",
              "description": "Path to the kustomization directory relative to sourceDirectory. When set, Flux Sync.Path is configured to this path so Flux uses the specified kustomization as the entry point instead of requiring a root kustomization.yaml."
            },
            "watch": {
              "properties": {
                "hooks": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Shell commands to run before each apply (e.g. docker build, make generate). Executed sequentially; if any hook fails the apply is skipped."
                }
              },
              "additionalProperties": false,
              "type": "object",
              "description": "Configuration for the workload watch command (pre-apply hooks, etc.)"
            }
          },
          "additionalProperties": false,
          "type": "object"
        },
        "chat": {
          "properties": {
            "model": {
              "type": "string",
              "description": "Chat model (empty or 'auto' for API default)"
            },
            "reasoningEffort": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "description": "Reasoning effort level for chat responses (low, medium, or high)"
            }
          },
          "additionalProperties": false,
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "spec"
  ],
  "title": "KSail Cluster Configuration",
  "description": "JSON schema for KSail cluster configuration (ksail.yaml)"
}