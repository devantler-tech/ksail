      "tcp": {
        "description": "Port pairs can be specified as '\u003cport\u003e:\u003ctargetPort\u003e'. (applies to: create_service_clusterip, create_service_externalname, create_service_loadbalancer, create_service_nodeport)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "template": {
        "description": "Template string or path to template file to use when -o=go-template, -o=go-template-file. The template format is golang templates [http://golang.org/pkg/text/template/#pkg-overview].",
        "type": "string"
      },
