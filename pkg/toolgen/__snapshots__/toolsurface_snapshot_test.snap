[TestToolSurfaceSnapshot/cluster_read - 1]
{
  "name": "cluster_read",
  "title": "Cluster Read",
  "description": "Manage cluster lifecycle",
  "commandPath": "ksail cluster",
  "requiresPermission": false,
  "isConsolidated": true,
  "subcommandParam": "command",
  "annotations": {
    "readOnlyHint": true,
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": true
  },
  "parameters": {
    "properties": {
      "args": {
        "description": "Positional arguments for the command",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "command": {
        "description": "The subcommand to execute. Options:\ndiagnose: Diagnose failing cluster resources\ndiff: Show configuration drift between ksail.yaml and live cluster\ninfo: Display cluster information\nlist: List clusters\nrepair: Repair local KSail/Talos state files",
        "enum": [
          "diagnose",
          "diff",
          "info",
          "list",
          "repair"
        ],
        "type": "string"
      },
      "context": {
        "description": "Kubernetes context of cluster (applies to: diff)",
        "type": "string"
      },
      "distribution": {
        "description": "Kubernetes distribution to use (applies to: diff)",
        "type": "string"
      },
      "distribution-config": {
        "description": "Configuration file for the distribution (applies to: diff)",
        "type": "string"
      },
      "exit-code": {
        "description": "Return exit code 2 when drift is detected (for CI gates) (applies to: diff)",
        "type": "boolean"
      },
      "gitops-engine": {
        "default": "None",
        "description": "GitOps engine to use (None disables GitOps, Flux installs Flux controllers, ArgoCD installs Argo CD) (applies to: diff)",
        "type": "string"
      },
      "include-version-drift": {
        "description": "Also report distribution/Kubernetes version drift the next 'cluster update' would reconcile (performs OCI registry lookups; off by default) (applies to: diff)",
        "type": "boolean"
      },
      "kubeconfig": {
        "default": "~/.kube/config",
        "description": "Path to kubeconfig file (applies to: diff)",
        "type": "string"
      },
      "local-registry": {
        "description": "Local registry specification: [user:pass@]host[:port][/path] (e.g., localhost:5050, ghcr.io/myorg, ${USER}:${PASS}@ghcr.io:443/org) (applies to: diff)",
        "type": "string"
      },
      "name": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "output": {
        "default": "text",
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "provider": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "talosconfig": {
        "description": "path to talosconfig (default: ~/.talos/config) (applies to: repair)",
        "type": "string"
      }
    },
    "required": [
      "command"
    ],
    "type": "object"
  }
}
---

[TestToolSurfaceSnapshot/tenant_write - 1]
{
  "name": "tenant_write",
  "title": "Tenant Write",
  "description": "Manage tenant lifecycle",
  "commandPath": "ksail tenant",
  "requiresPermission": true,
  "isConsolidated": true,
  "subcommandParam": "tenant_command",
  "annotations": {
    "readOnlyHint": false,
    "destructiveHint": true,
    "idempotentHint": false,
    "openWorldHint": true
  },
  "parameters": {
    "properties": {
      "args": {
        "description": "Positional arguments for the command",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "cluster-role": {
        "default": [
          "edit"
        ],
        "description": "ClusterRole(s) to bind to the tenant ServiceAccount (repeatable)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "delete-repo": {
        "description": "Also delete the tenant Git repository",
        "type": "boolean"
      },
      "delivery": {
        "default": "commit",
        "description": "How to deliver platform changes: commit or pr",
        "type": "string"
      },
      "disable-token-automount": {
        "description": "Set automountServiceAccountToken: false on the tenant ServiceAccount",
        "type": "boolean"
      },
      "flux-decryption": {
        "description": "(Flux) Add a SOPS decryption block referencing the sops-age secret",
        "type": "boolean"
      },
      "flux-retry-interval": {
        "description": "(Flux) Flux Kustomization retryInterval",
        "type": "string"
      },
      "flux-timeout": {
        "description": "(Flux) Flux Kustomization timeout; setting it implies --flux-wait (default 5m when waiting)",
        "type": "string"
      },
      "flux-wait": {
        "description": "(Flux) Set wait: true and timeout on the Flux Kustomization",
        "type": "boolean"
      },
      "force": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "boolean"
      },
      "git-provider": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "git-token": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "image-pull-secret": {
        "description": "imagePullSecret to add to the tenant ServiceAccount (repeatable)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "kustomization-path": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "limit-default-cpu": {
        "default": "500m",
        "description": "Default container CPU limit",
        "type": "string"
      },
      "limit-default-memory": {
        "default": "512Mi",
        "description": "Default container memory limit",
        "type": "string"
      },
      "limit-request-cpu": {
        "default": "100m",
        "description": "Default container CPU request",
        "type": "string"
      },
      "limit-request-memory": {
        "default": "128Mi",
        "description": "Default container memory request",
        "type": "string"
      },
      "namespace": {
        "description": "Namespaces to create (repeatable, default: tenant-name)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "oci-path": {
        "description": "Path suffix appended to OCI registry URL to avoid tag collisions (e.g., 'manifests' produces oci://registry/owner/repo/manifests)",
        "type": "string"
      },
      "output": {
        "default": ".",
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "platform-repo": {
        "description": "Platform repo as owner/repo-name for PR delivery (default: auto-detect from git remote)",
        "type": "string"
      },
      "pod-security": {
        "description": "Pod Security Standards level for namespaces: restricted, baseline, or privileged",
        "type": "string"
      },
      "production": {
        "description": "Enable the recommended production baseline (PSS baseline, default-deny NetworkPolicy, ResourceQuota, LimitRange, hardened ServiceAccount and Flux sync)",
        "type": "boolean"
      },
      "quota-cpu": {
        "default": "4",
        "description": "CPU quota (sets requests.cpu and limits.cpu)",
        "type": "string"
      },
      "quota-memory": {
        "default": "8Gi",
        "description": "Memory quota (sets requests.memory and limits.memory)",
        "type": "string"
      },
      "register": {
        "description": "Register tenant in kustomization.yaml",
        "type": "boolean"
      },
      "registry": {
        "description": "OCI registry URL for Flux OCI source (e.g., oci://ghcr.io)",
        "type": "string"
      },
      "repo-visibility": {
        "default": "Private",
        "description": "Repo visibility: Private, Internal, or Public",
        "type": "string"
      },
      "source-directory": {
        "default": "k8s",
        "description": "Directory name for tenant manifests in the tenant repo",
        "type": "string"
      },
      "sync-source": {
        "default": "oci",
        "description": "Flux source type: oci or git",
        "type": "string"
      },
      "target-branch": {
        "description": "PR target branch (default: repo's default branch)",
        "type": "string"
      },
      "tenant-repo": {
        "description": "Behavior depends on the selected subcommand; see the matching CLI subcommand's --help for details",
        "type": "string"
      },
      "tenant_command": {
        "description": "The subcommand to execute. Options:\ncreate: Create a new tenant\ndelete: Delete a tenant",
        "enum": [
          "create",
          "delete"
        ],
        "type": "string"
      },
      "type": {
        "description": "Tenant type: flux, argocd, or kubectl (default: auto-detect from ksail.yaml gitOpsEngine)",
        "type": "string"
      },
      "unregister": {
        "default": true,
        "description": "Remove tenant from kustomization.yaml",
        "type": "boolean"
      },
      "with-limit-range": {
        "description": "Generate a LimitRange with default container requests/limits",
        "type": "boolean"
      },
      "with-network-policy": {
        "description": "Generate default-deny NetworkPolicy plus DNS and intra-namespace allow rules",
        "type": "boolean"
      },
      "with-quota": {
        "description": "Generate a ResourceQuota for each namespace",
        "type": "boolean"
      }
    },
    "required": [
      "tenant_command"
    ],
    "type": "object"
  }
}
