        "type": "boolean"
      },
      "sort-by": {
        "description": "If non-empty, sort list types using this field specification.  The field specification is expressed as a JSONPath expression (e.g. '{.metadata.name}')... (applies to: get)",
        "type": "string"
      },
      "source": {
        "description": "source that contains the chart (HelmRepository/name, GitRepository/name, Bucket/name) (applies to: gen_helmrelease)",
        "type": "string"
      },
      "storage-namespace": {
        "description": "namespace for Helm storage (applies to: gen_helmrelease)",
        "type": "string"
      },
      "strict": {
        "description": "Enable strict validation mode (applies to: validate)",
        "type": "boolean"
      },
      "subresource": {
        "description": "If specified, gets the subresource of the requested object. (applies to: get)",
        "type": "string"
      },
      "tail": {
        "default": -1,
        "description": "Lines of recent log file to display. Defaults to -1 with no selector, showing all log lines otherwise 10, if a selector is provided. (applies to: logs)",
        "type": "integer"
      },
      "target-namespace": {
        "description": "namespace to target when performing operations (applies to: gen_helmrelease)",
        "type": "string"
      },
      "tcp": {
        "description": "Port pairs can be specified as '\u003cport\u003e:\u003ctargetPort\u003e'. (applies to: gen_service_clusterip, gen_service_externalname, gen_service_loadbalancer, gen_service_nodeport)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "template": {
