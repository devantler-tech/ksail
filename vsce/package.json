{
  "name": "ksail",
  "displayName": "KSail",
  "description": "KSail - Kubernetes SDK for Local GitOps Development",
  "version": "0.1.0",
  "publisher": "devantler",
  "icon": "resources/icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/devantler-tech/ksail"
  },
  "homepage": "https://ksail.devantler.tech/",
  "bugs": {
    "url": "https://github.com/devantler-tech/ksail/issues"
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "kubernetes",
    "kubernetes-extension-cloud-provider",
    "k8s",
    "gitops",
    "flux",
    "kind",
    "k3d",
    "talos",
    "mcp",
    "mcp-server"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "extensionDependencies": [
    "ms-kubernetes-tools.vscode-kubernetes-tools"
  ],
  "activationEvents": [
    "onView:extension.vsKubernetesExplorer",
    "onView:kubernetes.cloudExplorer",
    "onCommand:ksail.refresh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "ksail",
        "label": "KSail MCP Server"
      }
    ],
    "commands": [
      {
        "command": "ksail.refresh",
        "title": "Refresh Clusters",
        "category": "KSail",
        "icon": "$(refresh)"
      },
      {
        "command": "ksail.cluster.init",
        "title": "Init Cluster",
        "category": "KSail",
        "icon": "$(add)"
      },
      {
        "command": "ksail.cluster.create",
        "title": "Create Cluster",
        "category": "KSail",
        "icon": "$(play)"
      },
      {
        "command": "ksail.cluster.delete",
        "title": "Delete Cluster",
        "category": "KSail",
        "icon": "$(trash)"
      },
      {
        "command": "ksail.cluster.start",
        "title": "Start Cluster",
        "category": "KSail",
        "icon": "$(debug-start)"
      },
      {
        "command": "ksail.cluster.stop",
        "title": "Stop Cluster",
        "category": "KSail",
        "icon": "$(debug-stop)"
      },
      {
        "command": "ksail.cluster.connect",
        "title": "Connect to Cluster (K9s)",
        "category": "KSail",
        "icon": "$(terminal)"
      },
      {
        "command": "ksail.cluster.info",
        "title": "Show KSail Info",
        "category": "KSail",
        "icon": "$(info)"
      },
      {
        "command": "ksail.cluster.update",
        "title": "Update Cluster",
        "category": "KSail",
        "icon": "$(sync)"
      },
      {
        "command": "ksail.cluster.backup",
        "title": "Backup Cluster",
        "category": "KSail",
        "icon": "$(save)"
      },
      {
        "command": "ksail.cluster.restore",
        "title": "Restore Cluster",
        "category": "KSail",
        "icon": "$(history)"
      },
      {
        "command": "ksail.cluster.switch",
        "title": "Switch Cluster",
        "category": "KSail",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "ksail.showOutput",
        "title": "Show Output",
        "category": "KSail",
        "icon": "$(output)"
      },
      {
        "command": "ksail.status.showPodLogs",
        "title": "Show Pod Logs",
        "category": "KSail",
        "icon": "$(output)"
      }
    ],
    "keybindings": [
      {
        "command": "ksail.cluster.init",
        "key": "ctrl+shift+k i",
        "mac": "cmd+shift+k i"
      },
      {
        "command": "ksail.cluster.create",
        "key": "ctrl+shift+k c",
        "mac": "cmd+shift+k c"
      },
      {
        "command": "ksail.cluster.delete",
        "key": "ctrl+shift+k d",
        "mac": "cmd+shift+k d"
      }
    ],
    "configuration": {
      "title": "KSail",
      "properties": {
        "ksail.binaryPath": {
          "type": "string",
          "default": "ksail",
          "description": "Path to the KSail binary"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "ksail.refresh",
          "when": "false"
        },
        {
          "command": "ksail.status.showPodLogs",
          "when": "false"
        }
      ],
      "view/title": [],
      "view/item/context": [
        {
          "command": "ksail.cluster.create",
          "when": "viewItem == kubernetes.cloudExplorer.cloud.KSail",
          "group": "0@1"
        },
        {
          "command": "ksail.cluster.info",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "0@1"
        },
        {
          "command": "ksail.cluster.info",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "0@1"
        },
        {
          "command": "ksail.cluster.start",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "1@1"
        },
        {
          "command": "ksail.cluster.start",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "1@1"
        },
        {
          "command": "ksail.cluster.stop",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "1@2"
        },
        {
          "command": "ksail.cluster.stop",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "1@2"
        },
        {
          "command": "ksail.cluster.connect",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "1@3"
        },
        {
          "command": "ksail.cluster.connect",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "1@3"
        },
        {
          "command": "ksail.cluster.update",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "1@4"
        },
        {
          "command": "ksail.cluster.update",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "1@4"
        },
        {
          "command": "ksail.cluster.switch",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "1@5"
        },
        {
          "command": "ksail.cluster.switch",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "1@5"
        },
        {
          "command": "ksail.cluster.backup",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "2@1"
        },
        {
          "command": "ksail.cluster.backup",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "2@1"
        },
        {
          "command": "ksail.cluster.restore",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "2@2"
        },
        {
          "command": "ksail.cluster.restore",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "2@2"
        },
        {
          "command": "ksail.cluster.delete",
          "when": "view == extension.vsKubernetesExplorer && viewItem =~ /ksail\\.cluster/i",
          "group": "3@1"
        },
        {
          "command": "ksail.cluster.delete",
          "when": "viewItem =~ /ksail-cluster-/",
          "group": "3@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test",
    "clean": "rm -rf dist out"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "diff": "^8.0.3",
    "brace-expansion": "^5.0.5",
    "yauzl": "^3.2.1"
  },
  "dependencies": {
    "vscode-kubernetes-tools-api": "^1.3.0"
  }
}
