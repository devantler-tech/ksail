---
---

<div class="benchmark-charts" id="benchmark-charts">
  <p class="benchmark-loading">Loading benchmark data…</p>
</div>

<!--
  Use is:inline because Astro does not process/bundle <script> tags in
  .astro components that are imported via MDX.  type="module" enables
  top-level await and dynamic import() from the CDN.
-->
<script is:inline type="module">
  const { Chart } = await import("https://esm.sh/chart.js@4.4.9/auto");

  const COLORS = [
    "#3182ce",
    "#e53e3e",
    "#38a169",
    "#d69e2e",
    "#805ad5",
    "#dd6b20",
    "#319795",
    "#d53f8c",
  ];

  const METRICS = ["ns/op", "B/op", "allocs/op"];

  function parseCanonicalName(name) {
    const pkgMatch = name.match(/\(github\.com\/devantler-tech\/ksail\/v5\/([^)]+)\)/);
    if (!pkgMatch) return null;

    let metric = null;
    for (const m of METRICS) {
      if (name.endsWith(" - " + m)) {
        metric = m;
        break;
      }
    }
    if (!metric) return null;

    const benchPart = name.split("(")[0].trim().replace(/^Benchmark/, "");
    const slashIdx = benchPart.indexOf("/");
    const stem = slashIdx === -1 ? benchPart : benchPart.substring(0, slashIdx);
    const subtest = slashIdx === -1 ? null : benchPart.substring(slashIdx + 1);

    return {
      pkg: pkgMatch[1],
      stem,
      subtest,
      metric,
      fullName: name,
    };
  }

  function buildTimeSeries(entries) {
    const series = {};
    for (const entry of entries) {
      const date = new Date(entry.date);
      for (const bench of entry.benches) {
        if (!series[bench.name]) series[bench.name] = [];
        series[bench.name].push({ date, value: bench.value });
      }
    }
    return series;
  }

  function shortPkgName(pkg) {
    return pkg.replace(/^pkg\//, "");
  }

  function slugify(text) {
    return text.replace(/[^a-z0-9]+/gi, "-").toLowerCase();
  }

  function detectTheme() {
    const isDark =
      document.documentElement.dataset.theme === "dark" ||
      document.documentElement.classList.contains("dark") ||
      window.matchMedia("(prefers-color-scheme: dark)").matches;
    return {
      gridColor: isDark ? "rgba(255,255,255,0.1)" : "rgba(0,0,0,0.1)",
      textColor: isDark ? "rgba(255,255,255,0.7)" : "rgba(0,0,0,0.7)",
    };
  }

  function createChart(canvas, datasets, unit, theme) {
    return new Chart(canvas, {
      type: "line",
      data: { datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        scales: {
          x: {
            type: "linear",
            ticks: {
              color: theme.textColor,
              callback: (v) =>
                new Date(v).toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                }),
            },
            grid: { color: theme.gridColor },
          },
          y: {
            title: { display: true, text: unit, color: theme.textColor },
            ticks: { color: theme.textColor },
            grid: { color: theme.gridColor },
          },
        },
        plugins: {
          tooltip: {
            callbacks: {
              title: (items) => {
                const ts = items[0]?.parsed?.x;
                return ts
                  ? new Date(ts).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })
                  : "";
              },
              label: (ctx) =>
                `${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString()} ${unit}`,
            },
          },
          legend: {
            labels: { color: theme.textColor },
          },
        },
      },
    });
  }

  async function renderCharts() {
    const container = document.getElementById("benchmark-charts");
    if (!container) return;

    let data;
    try {
      const res = await fetch("/benchmark-data.json");
      if (!res.ok) throw new Error(res.statusText);
      data = await res.json();
    } catch {
      container.innerHTML =
        '<p class="benchmark-empty">No benchmark data available yet. Data appears after the first push to <code>main</code>.</p>';
      return;
    }

    const entries = Object.values(data.entries).flat();
    if (entries.length === 0) {
      container.innerHTML =
        '<p class="benchmark-empty">No benchmark runs recorded yet.</p>';
      return;
    }

    const allNames = [
      ...new Set(entries.flatMap((e) => e.benches.map((b) => b.name))),
    ];
    const series = buildTimeSeries(entries);

    // Parse and filter to canonical entries only (pkg-qualified + metric-specific)
    const parsed = allNames.map(parseCanonicalName).filter(Boolean);

    // Build hierarchy: package → stem → metric → [subtests]
    const hierarchy = {};
    for (const p of parsed) {
      if (!hierarchy[p.pkg]) hierarchy[p.pkg] = {};
      if (!hierarchy[p.pkg][p.stem]) hierarchy[p.pkg][p.stem] = {};
      if (!hierarchy[p.pkg][p.stem][p.metric])
        hierarchy[p.pkg][p.stem][p.metric] = [];
      hierarchy[p.pkg][p.stem][p.metric].push(p);
    }

    const theme = detectTheme();
    const sortedPkgs = Object.keys(hierarchy).sort();

    // Build TOC
    const toc = document.createElement("nav");
    toc.className = "benchmark-toc";
    const tocHeading = document.createElement("strong");
    tocHeading.textContent = "Packages";
    toc.appendChild(tocHeading);
    const tocList = document.createElement("ul");
    for (const pkg of sortedPkgs) {
      const stemCount = Object.keys(hierarchy[pkg]).length;
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = "#bench-" + slugify(pkg);
      a.textContent = shortPkgName(pkg);
      li.appendChild(a);
      const badge = document.createElement("span");
      badge.className = "benchmark-badge";
      badge.textContent = stemCount.toString();
      li.appendChild(badge);
      tocList.appendChild(li);
    }
    toc.appendChild(tocList);

    container.innerHTML = "";
    container.appendChild(toc);

    // When a TOC link is clicked, open the target <details> section
    toc.addEventListener("click", (e) => {
      const anchor = e.target.closest("a");
      if (!anchor) return;
      const targetId = anchor.getAttribute("href")?.substring(1);
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (target && target.tagName === "DETAILS" && !target.open) {
        target.open = true;
      }
    });

    // Render each package section
    for (const pkg of sortedPkgs) {
      const stems = hierarchy[pkg];
      const sortedStems = Object.keys(stems).sort();
      const stemCount = sortedStems.length;

      const details = document.createElement("details");
      details.className = "benchmark-pkg-section";
      details.id = "bench-" + slugify(pkg);

      const summary = document.createElement("summary");
      const summaryText = document.createElement("span");
      summaryText.textContent = shortPkgName(pkg);
      summary.appendChild(summaryText);
      const summaryBadge = document.createElement("span");
      summaryBadge.className = "benchmark-badge";
      summaryBadge.textContent =
        stemCount + (stemCount === 1 ? " benchmark" : " benchmarks");
      summary.appendChild(summaryBadge);
      details.appendChild(summary);

      const sectionContent = document.createElement("div");
      sectionContent.className = "benchmark-pkg-content";
      details.appendChild(sectionContent);
      container.appendChild(details);

      // Lazily create charts only when the section is first opened,
      // so canvas elements have visible dimensions for correct sizing.
      let initialized = false;
      details.addEventListener("toggle", () => {
        if (!details.open || initialized) return;
        initialized = true;

        for (const stem of sortedStems) {
          const metricsData = stems[stem];
          const chartBlock = document.createElement("div");
          chartBlock.className = "benchmark-chart-block";

          const heading = document.createElement("h4");
          heading.textContent = stem;
          chartBlock.appendChild(heading);

          const tabBar = document.createElement("div");
          tabBar.className = "benchmark-tab-bar";
          const canvasWrap = document.createElement("div");
          canvasWrap.className = "benchmark-canvas-wrap";
          const canvas = document.createElement("canvas");
          canvasWrap.appendChild(canvas);

          let activeChart = null;

          function renderMetric(metric) {
            const benchmarks = metricsData[metric] || [];
            const datasets = benchmarks
              .sort((a, b) =>
                (a.subtest || "").localeCompare(b.subtest || ""),
              )
              .map((b, i) => {
                const points = (series[b.fullName] || []).sort(
                  (a, b) => a.date.getTime() - b.date.getTime(),
                );
                return {
                  label: b.subtest || stem,
                  data: points.map((p) => ({
                    x: p.date.getTime(),
                    y: p.value,
                  })),
                  borderColor: COLORS[i % COLORS.length],
                  backgroundColor: COLORS[i % COLORS.length] + "33",
                  tension: 0.3,
                  pointRadius: 3,
                  pointHoverRadius: 6,
                  fill: false,
                };
              });

            if (activeChart) activeChart.destroy();
            activeChart = createChart(canvas, datasets, metric, theme);
          }

          for (const metric of METRICS) {
            if (!metricsData[metric]) continue;
            const tab = document.createElement("button");
            tab.className = "benchmark-tab";
            tab.textContent = metric;
            tab.addEventListener("click", () => {
              tabBar
                .querySelectorAll(".benchmark-tab")
                .forEach((t) => t.classList.remove("active"));
              tab.classList.add("active");
              renderMetric(metric);
            });
            tabBar.appendChild(tab);
          }

          const firstTab = tabBar.querySelector(".benchmark-tab");
          if (firstTab) {
            firstTab.classList.add("active");
            chartBlock.appendChild(tabBar);
            chartBlock.appendChild(canvasWrap);
            const firstMetric = METRICS.find((m) => metricsData[m]);
            if (firstMetric) renderMetric(firstMetric);
          }

          sectionContent.appendChild(chartBlock);
        }
      });
    }
  }

  renderCharts();
</script>

<!--
  Use is:global because dynamically created elements won't have Astro's
  scoping class.  Selectors are scoped under #benchmark-charts.
-->
<style is:global>
  #benchmark-charts {
    margin: 1.5rem 0;
  }

  #benchmark-charts .benchmark-loading,
  #benchmark-charts .benchmark-empty {
    color: var(--sl-color-gray-3, #888);
    font-style: italic;
    text-align: center;
    padding: 2rem 1rem;
  }

  /* Table of contents */
  #benchmark-charts .benchmark-toc {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--sl-color-bg-nav, transparent);
    border: 1px solid var(--sl-color-hairline, rgba(128, 128, 128, 0.2));
    border-radius: 0.75rem;
  }

  #benchmark-charts .benchmark-toc strong {
    display: block;
    margin-bottom: 0.5rem;
  }

  #benchmark-charts .benchmark-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  #benchmark-charts .benchmark-toc li {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  #benchmark-charts .benchmark-toc a {
    color: var(--sl-color-text-accent, #3182ce);
    text-decoration: none;
    font-size: 0.9rem;
  }

  #benchmark-charts .benchmark-toc a:hover {
    text-decoration: underline;
  }

  /* Badge */
  #benchmark-charts .benchmark-badge {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: var(--sl-color-gray-6, rgba(128, 128, 128, 0.15));
    color: var(--sl-color-gray-2, #aaa);
    line-height: 1.4;
  }

  /* Collapsible package sections */
  #benchmark-charts .benchmark-pkg-section {
    margin-bottom: 1rem;
    border: 1px solid var(--sl-color-hairline, rgba(128, 128, 128, 0.2));
    border-radius: 0.75rem;
    overflow: hidden;
  }

  #benchmark-charts .benchmark-pkg-section summary {
    cursor: pointer;
    padding: 0.75rem 1.25rem;
    font-weight: 600;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--sl-color-bg-nav, transparent);
    user-select: none;
  }

  #benchmark-charts .benchmark-pkg-section summary:hover {
    background: var(--sl-color-gray-7, rgba(128, 128, 128, 0.05));
  }

  #benchmark-charts .benchmark-pkg-content {
    padding: 0.75rem 1.25rem 1.25rem;
  }

  /* Individual chart blocks */
  #benchmark-charts .benchmark-chart-block {
    margin-bottom: 2rem;
  }

  #benchmark-charts .benchmark-chart-block:last-child {
    margin-bottom: 0;
  }

  #benchmark-charts .benchmark-chart-block h4 {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
  }

  /* Metric tab bar */
  #benchmark-charts .benchmark-tab-bar {
    display: flex;
    gap: 0;
    margin-bottom: 0;
  }

  #benchmark-charts .benchmark-tab {
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--sl-color-hairline, rgba(128, 128, 128, 0.2));
    border-bottom: none;
    background: transparent;
    color: var(--sl-color-gray-2, #aaa);
    cursor: pointer;
    font-size: 0.8rem;
    font-family: inherit;
    border-radius: 0.5rem 0.5rem 0 0;
    transition: background 0.15s, color 0.15s;
  }

  #benchmark-charts .benchmark-tab:hover {
    background: var(--sl-color-gray-7, rgba(128, 128, 128, 0.05));
  }

  #benchmark-charts .benchmark-tab.active {
    background: var(--sl-color-bg-nav, transparent);
    color: var(--sl-color-text, #fff);
    border-bottom-color: var(--sl-color-bg-nav, transparent);
    font-weight: 600;
  }

  /* Chart canvas */
  #benchmark-charts .benchmark-canvas-wrap {
    position: relative;
    height: 320px;
    width: 100%;
    background: var(--sl-color-bg-nav, transparent);
    border-radius: 0 0.75rem 0.75rem 0.75rem;
    padding: 1rem;
    border: 1px solid var(--sl-color-hairline, rgba(128, 128, 128, 0.2));
  }
</style>
