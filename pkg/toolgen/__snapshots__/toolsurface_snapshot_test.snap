  "description": "Manage workload operations",
  "commandPath": "ksail workload",
  "requiresPermission": false,
  "isConsolidated": true,
  "subcommandParam": "workload_command",
  "annotations": {
    "readOnlyHint": true,
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": true
  },
  "parameters": {
    "properties": {
      "address": {
        "default": [
          "localhost"
